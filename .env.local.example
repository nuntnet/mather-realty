# ═══ DoubleN Realty — Local Environment Template ═══
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.

# ─── Notion CMS ───
NOTION_API_KEY=<your-notion-integration-secret>
NOTION_PROPERTIES_DB_ID=<notion-properties-database-id>
NOTION_BLOG_DB_ID=<notion-blog-database-id>
NOTION_PAGES_DB_ID=<notion-pages-database-id>

# ─── Auth & Security ───
BETTER_AUTH_SECRET=<openssl-rand-base64-32>
BETTER_AUTH_URL=http://localhost:3002
REVALIDATE_SECRET=<openssl-rand-base64-32>

# ─── Turso (SQLite) ───
TURSO_DATABASE_URL=libsql://<db-name>.aws-ap-northeast-1.turso.io
TURSO_AUTH_TOKEN=<turso-auth-token>

# ─── Cloudinary ───
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>

# ─── Google Maps ───
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<your-google-maps-api-key>

# ─── Algolia ───
ALGOLIA_APP_ID=<your-algolia-app-id>
NEXT_PUBLIC_ALGOLIA_APP_ID=<your-algolia-app-id>
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=<your-algolia-search-only-api-key>
ALGOLIA_ADMIN_KEY=<your-algolia-admin-api-key>

# ─── AI (multilingual property descriptions, personas, FAQ) ───
# Primary provider: Google Gemini via its OpenAI-compatible endpoint.
# callAI() tries providers in order: Hermes → Gemini → Anthropic → OpenAI.
# Set GOOGLE_AI_API_KEY and Gemini is used automatically.
GOOGLE_AI_API_KEY=<your-gemini-api-key>           # https://aistudio.google.com/apikey
# Optional: pin a single model (else falls back across 2.5-flash-lite → 2.5-flash → 2.0-*)
# GEMINI_MODEL=gemini-2.5-flash-lite
# Optional fallback only — not required when GOOGLE_AI_API_KEY is set
# OPENAI_API_KEY=<your-openai-api-key>

# ─── Resend (email notifications) ───
RESEND_API_KEY=<your-resend-api-key>

# ─── Admin ───
ADMIN_EMAIL=admin@doublen-realty.com

# ─── Site URL ───
NEXT_PUBLIC_SITE_URL=http://localhost:3002
