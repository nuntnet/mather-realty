# ─── Auth & Security (Staging) ────────────────────────
BETTER_AUTH_SECRET=<get-from-vercel-dashboard>
BETTER_AUTH_URL=https://ch-erawan-next-website-staging.vercel.app
REVALIDATE_SECRET=<get-from-vercel-dashboard>

# ─── Database (Turso Staging) ─────────────────────────
TURSO_DATABASE_URL=libsql://ch-erawan-staging-cherawansystem.aws-ap-northeast-1.turso.io
TURSO_AUTH_TOKEN=<get-from-vercel-dashboard>

# ─── Cloudinary (Shared with prod — read-only) ───────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=n5llrdnq
CLOUDINARY_API_KEY=<get-from-vercel-dashboard>
CLOUDINARY_API_SECRET=<get-from-vercel-dashboard>

# ─── Google Maps (Shared) ────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<get-from-vercel-dashboard>

# ─── Site URL (Staging) ──────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ch-erawan-next-website-staging.vercel.app
